# ─── Required ────────────────────────────────────────────────────
# PostgreSQL connection string (provided automatically by Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server binds to (provided automatically by Render)
PORT=8080

# ─── Optional ────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Leave empty to allow all origins (fine for development only).
# In production, set this to your Vercel frontend URL.
CORS_ORIGIN=https://your-app.vercel.app

# Node environment
NODE_ENV=production
