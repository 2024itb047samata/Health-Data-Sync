# ─── Required for production ─────────────────────────────────────
# Full URL of your Render API server (no trailing slash).
# Leave empty in local development — the Vite dev proxy handles routing.
VITE_API_URL=https://your-api.onrender.com

# ─── Build-time ──────────────────────────────────────────────────
# Base path the frontend is served from. Always "/" on Vercel.
# Set automatically by the build system; you can also define it in vercel.json.
BASE_PATH=/
